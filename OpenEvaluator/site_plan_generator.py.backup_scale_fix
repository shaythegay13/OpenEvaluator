def generate_locus_map(data: dict, out_path=None) -> Optional[Path]:
    out_path = out_path or OUTPUT_DIR / "locus_map.png"
    town    = data.get("town", "")
    tax_map = data.get("tax_map", "")
    lot_no  = data.get("lot_number", "")
    road    = (data.get("road_name") or data.get("street_name") or "ROAD").upper()

    try:
        fig, ax = plt.subplots(figsize=(2.5, 3.09), dpi=DPI)
        ax.set_facecolor("white")
        fig.patch.set_facecolor("white")
        for sp in ax.spines.values():
            sp.set_visible(False)
        ax.set_xticks([])
        ax.set_yticks([])

        parcel = _fetch_parcel(town, tax_map, lot_no)
        if parcel:
            _draw_geojson_locus(ax, parcel, lot_no, town)
        else:
            _draw_schematic_locus(ax, lot_no, tax_map, road)

        ax.axis("off")
        plt.tight_layout(pad=0.1)
        plt.savefig(str(out_path), dpi=DPI, bbox_inches=None,
                    facecolor="white", edgecolor="none")
        plt.close(fig)
        return out_path
    except Exception as e:
        print(f"  Warning: locus map failed: {e}")
        return None


def _fetch_parcel(town, map_no, lot_no):
    if not (town and map_no and lot_no):
        return None
    base   = ("https://arcgis.maine.gov/arcgis/rest/services"
               "/Property/MEMainePropertyTax/MapServer/0/query")
    params = urllib.parse.urlencode({
        "where": (f"UPPER(TOWN_NAME)='{town.strip().upper()}'"
                  f" AND MAP_NO='{map_no.strip()}'"
                  f" AND LOT_NO='{lot_no.strip()}'"),
        "outFields": "TOWN_NAME,MAP_NO,LOT_NO,ACRES",
        "outSR": "4326", "f": "geojson", "geometryPrecision": 6,
    })
    try:
        req = urllib.request.Request(
            f"{base}?{params}", headers={"User-Agent": "OpenEvaluator-HHE200/1.0"}
        )
        with urllib.request.urlopen(req, timeout=12) as r:
            gj = json.loads(r.read())
        feats = gj.get("features", [])
        if feats:
            print(f"  GIS: found parcel {map_no}/{lot_no} in {town}")
            return feats[0]
    except Exception as e:
        print(f"  GIS fetch error: {e} — using schematic")
    return None


def _draw_geojson_locus(ax, feature, lot_no, town):
    geom   = feature.get("geometry", {})
    coords = geom.get("coordinates", [])
    if not coords:
        return _draw_schematic_locus(ax, lot_no, "", town)
    ring = np.array(coords[0])
    mn, mx2 = ring.min(axis=0), ring.max(axis=0)
    span = (mx2 - mn).max()
    if span < 1e-9:
        return _draw_schematic_locus(ax, lot_no, "", town)
    rn = (ring - mn) / span * 0.70 + 0.13
    ax.add_patch(MplPolygon(rn, closed=True, facecolor=C_WATER,
                            edgecolor="black", linewidth=2.0, zorder=2))
    cx2, cy2 = rn[:, 0].mean(), rn[:, 1].mean()
    ax.text(cx2, cy2 + 0.04, "SITE",          ha="center", va="center", fontsize=6.5, fontweight="bold")
    ax.text(cx2, cy2 - 0.06, f"LOT {lot_no}", ha="center", va="center", fontsize=5.5)
    ax.text(0.5, 0.02, town.upper(), ha="center", va="bottom", fontsize=5, transform=ax.transAxes)
    _locus_n(ax)
    ax.set_xlim(0, 1); ax.set_ylim(0, 1)


def _draw_schematic_locus(ax, lot_no, tax_map, road_name):
    # Road
    ax.add_patch(Rectangle((0, 0.86), 1, 0.14, facecolor=C_ROAD, edgecolor="none"))
    ax.text(0.5, 0.93, road_name, ha="center", va="center", fontsize=5.5, fontweight="bold")
    ax.add_patch(Rectangle((0, 0.86), 1, 0.01, facecolor="black", edgecolor="none"))
    # Site parcel
    ax.add_patch(Rectangle((0.27, 0.28), 0.45, 0.56, facecolor=C_WATER,
                            edgecolor="black", linewidth=2.5))
    ax.text(0.495, 0.60, "SITE",          ha="center", va="center", fontsize=7,   fontweight="bold")
    ax.text(0.495, 0.50, f"LOT {lot_no}", ha="center", va="center", fontsize=5.5)
    ax.text(0.495, 0.40, f"MAP {tax_map}", ha="center", va="center", fontsize=5)
    # Adjacent lots
    for lx, lw2 in [(0.02, 0.23), (0.74, 0.24)]:
        ax.add_patch(Rectangle((lx, 0.28), lw2, 0.56, facecolor="#f0f0f0",
                                edgecolor="black", linewidth=0.8))
        ax.text(lx + lw2 / 2, 0.56, "ADJ.\nLOT", ha="center", va="center", fontsize=4.5)
    # Bottom area (lower lots)
    ax.add_patch(Rectangle((0.02, 0.04), 0.96, 0.22, facecolor="#f8f8f8",
                            edgecolor="black", linewidth=0.8))
    ax.text(0.5, 0.15, "ADJ. LOT", ha="center", va="center", fontsize=4.5)
    _locus_n(ax)
    ax.set_xlim(0, 1); ax.set_ylim(0, 1)


def _locus_n(ax):
    ax.annotate("", xy=(0.92, 0.84), xytext=(0.92, 0.71),
                xycoords="axes fraction", textcoords="axes fraction",
                arrowprops=dict(arrowstyle="-|>", color="black", lw=1.5))
    ax.text(0.92, 0.86, "N", ha="center", va="bottom", fontsize=8,
            fontweight="bold", transform=ax.transAxes)


