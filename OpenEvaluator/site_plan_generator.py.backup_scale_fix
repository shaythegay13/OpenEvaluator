def generate_all(data: dict, out_dir=None) -> dict:
    global OUTPUT_DIR
    if out_dir:
        OUTPUT_DIR = Path(out_dir)
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

    results = {}
    for key, fn, label in [
        ("site_plan_pg3",     generate_site_plan_pg3,    "Site plan (pg 3)"),
        ("disposal_plan_pg4", generate_disposal_plan_pg4, "Disposal plan (pg 4 top)"),
        ("cross_section_pg4", generate_cross_section_pg4, "Cross section (pg 4 bottom)"),
        ("locus_map",         generate_locus_map,          "Locus map"),
    ]:
        try:
            p = fn(data)
            if p:
                print(f"  OK {label}: {Path(p).name}")
                results[key] = str(p)
        except Exception as e:
            import traceback
            print(f"  FAIL {label}: {e}")
            traceback.print_exc()
    return results


